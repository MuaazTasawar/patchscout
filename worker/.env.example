# Server
PORT=8080

# Supabase
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# GitHub
GITHUB_TOKEN=your-github-personal-access-token

# Shared secret with Next.js callback endpoint
WORKER_CALLBACK_SECRET=shared-secret-between-web-and-worker
NEXT_CALLBACK_URL=https://your-vercel-app.vercel.app/api/webhook/worker-callback

# Clone workspace
CLONE_DIR=./clones